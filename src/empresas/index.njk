---
layout: layouts/empresas.njk
title: "Empresas — Cavero Diego"
description: "Pedidos mayoristas y acuerdos comerciales con Cavero Diego."
section: empresas
lang: es
langBtn: true
pageStyle: |
  /* ─── Tema verde oscuro ──────────────────────────────────── */
  :root {
    --emp-bg:      #2a3229;
    --emp-cream:   #e8e5dc;
    --emp-muted:   rgba(232,229,220,.35);
    --emp-border:  rgba(232,229,220,.08);
    --emp-green:   #98d624;
  }

  body { background: var(--emp-bg); color: var(--emp-cream); }

  /* Selección de texto con colores empresas */
  ::selection {
    background: var(--emp-green);
    color: var(--emp-bg);
  }

  /* Nav sobre fondo oscuro */
  nav { background: var(--emp-bg); }
  .nav-links a { color: var(--emp-cream); }
  .nav-links a.nav-empresas {
    color: var(--emp-cream);
    border-color: rgba(232,229,220,.2);
  }
  .nav-links a.nav-empresas:hover {
    border-color: var(--emp-cream);
    background: rgba(232,229,220,.06);
  }
  /* Subrayado de nav en empresas con color verde */
  .nav-links a::after {
    background: var(--emp-green);
  }
  .nav-links a.active::after {
    background: var(--emp-green);
  }
  .nav-lang-btn { color: var(--emp-cream); }
  .nav-cart-btn { color: var(--emp-cream); }
  .nav-logo-btn { filter: invert(1) brightness(1.5); }
  .nav-hamburger span { background: var(--emp-cream); }

  /* ─── Hero ───────────────────────────────────────────────── */
  .emp-hero {
    min-height: 60vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 6rem 8vw 5rem;
  }
  .emp-hero-eyebrow {
    font-size: .64rem; letter-spacing: .3em; text-transform: uppercase;
    color: var(--emp-muted); margin-bottom: 1.4rem; display: block;
  }
  .emp-hero-title {
    font-family: 'Boska', serif;
    font-size: clamp(2.8rem, 6vw, 6rem);
    font-weight: 400; line-height: .95;
    letter-spacing: -.02em;
    max-width: 14ch;
  }
  .emp-hero-title em { font-style: italic; color: var(--emp-green); }
  .emp-hero-desc {
    margin-top: 2.4rem;
    max-width: 48ch;
    font-size: .9rem;
    line-height: 1.7;
    color: var(--emp-muted);
  }

  /* ─── Usos ───────────────────────────────────────────────── */
  .emp-usos {
    padding: 6rem 8vw;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    border-bottom: 1px solid var(--emp-border);
  }
  .emp-uso {
    padding: 3rem 2.4rem;
    border-right: 1px solid var(--emp-border);
  }
  .emp-uso:last-child { border-right: none; }
  .emp-uso-icon {
    width: 36px; height: 36px;
    margin-bottom: 1.6rem;
    color: var(--emp-green);
  }
  .emp-uso-title {
    font-family: 'Boska', serif;
    font-size: 1.3rem; font-weight: 400;
    letter-spacing: -.01em;
    margin-bottom: .8rem;
  }
  .emp-uso-desc {
    font-size: .82rem; color: var(--emp-muted);
    line-height: 1.65;
  }

  /* ─── Ventajas ───────────────────────────────────────────── */
  .emp-ventajas {
    padding: 6rem 8vw;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5vw;
    align-items: center;
    border-bottom: 1px solid var(--emp-border);
  }
  .emp-ventajas-left .section-label {
    font-size: .64rem; letter-spacing: .25em; text-transform: uppercase;
    color: var(--emp-muted); display: block; margin-bottom: 1.6rem;
  }
  .emp-ventajas-title {
    font-family: 'Boska', serif;
    font-size: clamp(2rem, 3.5vw, 3.2rem);
    font-weight: 400; line-height: 1.05;
    letter-spacing: -.02em;
  }
  .emp-ventajas-title em { font-style: italic; color: var(--emp-green); }
  .emp-ventajas-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .emp-ventajas-list li {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    font-size: .85rem;
    line-height: 1.6;
    color: rgba(232,229,220,.75);
  }
  .emp-ventajas-list li::before {
    content: '';
    width: 5px; height: 5px;
    background: var(--emp-green);
    border-radius: 50%;
    margin-top: .55em;
    flex-shrink: 0;
  }

  /* ─── Proceso ────────────────────────────────────────────── */
  .emp-proceso {
    padding: 6rem 8vw;
    border-bottom: 1px solid var(--emp-border);
  }
  .emp-proceso-header { margin-bottom: 3.2rem; }
  .emp-proceso-header .section-label {
    font-size: .64rem; letter-spacing: .25em; text-transform: uppercase;
    color: var(--emp-muted); display: block; margin-bottom: 1rem;
  }
  .emp-proceso-header h2 {
    font-family: 'Boska', serif;
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    font-weight: 400; letter-spacing: -.02em;
  }
  .emp-pasos {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
  }
  .emp-paso {
    padding: 2.4rem 2rem;
    border-right: 1px solid var(--emp-border);
  }
  .emp-paso:last-child { border-right: none; }
  .emp-paso-num {
    font-size: .64rem; letter-spacing: .2em;
    color: var(--emp-green); margin-bottom: 1.2rem;
  }
  .emp-paso-title {
    font-size: .95rem; font-weight: 500;
    margin-bottom: .6rem;
  }
  .emp-paso-desc {
    font-size: .78rem; color: var(--emp-muted); line-height: 1.6;
  }

  /* ─── Formulario ──────────────────────────────────────────── */
  .emp-form-section {
    padding: 6rem 8vw;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8vw;
    background: rgba(255,255,255,.10);
    border-top: 1px solid var(--emp-border);
  }
  .emp-form-left .section-label {
    font-size: .64rem; letter-spacing: .25em; text-transform: uppercase;
    color: var(--emp-muted); display: block; margin-bottom: 1.6rem;
  }
  .emp-form-left h2 {
    font-family: 'Boska', serif;
    font-size: clamp(2rem, 3vw, 3rem);
    font-weight: 400; letter-spacing: -.02em;
    line-height: 1.05; margin-bottom: 1.6rem;
  }
  .emp-form-left p {
    font-size: .85rem; color: var(--emp-muted);
    line-height: 1.7; max-width: 40ch;
  }
  .emp-form-left .emp-contact-direct {
    margin-top: 2.4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--emp-border);
  }
  .emp-form-left .emp-contact-direct p {
    font-size: .75rem; color: var(--emp-muted); margin-bottom: .4rem;
  }
  .emp-form-left .emp-contact-direct a {
    font-size: .88rem; color: var(--emp-cream);
    text-decoration: none;
  }
  .emp-form-left .emp-contact-direct a:hover { color: var(--emp-green); }

  .emp-form-wrap {
    background: rgba(255,255,255,.10);
    border: 1px solid var(--emp-border);
    border-radius: 4px;
    padding: 2.4rem;
  }
  .emp-form {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }
  .emp-form .form-field {
    display: flex;
    flex-direction: column;
    gap: .4rem;
  }
  .emp-form .form-field label {
    font-size: .68rem; letter-spacing: .12em; text-transform: uppercase;
    color: var(--emp-muted);
  }
  .emp-form .form-field input,
  .emp-form .form-field select,
  .emp-form .form-field textarea {
    background: none;
    border: none;
    border-bottom: 1px solid var(--emp-border);
    padding: .7rem 0;
    font-family: 'Satoshi', sans-serif;
    font-size: .9rem;
    color: var(--emp-cream);
    outline: none;
    resize: none;
    transition: border-color .2s;
    -webkit-appearance: none;
  }
  .emp-form .form-field input::placeholder,
  .emp-form .form-field textarea::placeholder { color: var(--emp-muted); }
  .emp-form .form-field select option { background: var(--emp-bg); color: var(--emp-cream); }
  .emp-form .form-field input:focus,
  .emp-form .form-field select:focus,
  .emp-form .form-field textarea:focus { border-bottom-color: rgba(232,229,220,.5); }

  .emp-form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .emp-form-submit {
    margin-top: .8rem;
    background: var(--emp-green);
    color: var(--emp-bg);
    border: none;
    padding: 1.1rem 2rem;
    font-family: 'Satoshi', sans-serif;
    font-size: .78rem; letter-spacing: .2em; text-transform: uppercase;
    font-weight: 500;
    cursor: none;
    display: flex; align-items: center; gap: .8rem;
    transition: opacity .2s;
    border-radius: 2px;
    width: 100%;
    justify-content: center;
  }
  .emp-form-submit:hover { opacity: .85; }

  .emp-form-legal {
    font-size: .68rem; color: var(--emp-muted); text-align: center;
  }

  .emp-form-success {
    display: none;
    padding: 3rem 2rem;
    text-align: center;
    border: 1px solid var(--emp-border);
    border-radius: 4px;
  }
  .emp-form-success.visible { display: block; }
  .emp-form-success h3 {
    font-family: 'Boska', serif;
    font-size: 1.6rem; font-weight: 400;
    margin-bottom: .8rem;
  }
  .emp-form-success p {
    font-size: .82rem; color: var(--emp-muted);
  }

  /* ─── Footer ─────────────────────────────────────────────── */
  .emp-footer {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 6vw;
    padding: 2rem 8vw 2.4rem;
    border-top: 1px solid var(--emp-border);
  }
  /* Desktop: show logo+icons, hide card */
  .emp-footer-left {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1.6rem;
  }
  .emp-footer-left img {
    width: 38px;
    opacity: .5;
    filter: brightness(10);
  }
  .emp-footer-social {
    display: flex;
    gap: 1.2rem;
    align-items: center;
  }
  .emp-footer-social a {
    color: var(--emp-cream);
    opacity: .3;
    transition: opacity .2s;
  }
  .emp-footer-social a svg { width: 24px; height: 24px; }
  .emp-footer-social a:hover { opacity: .8; }
  .emp-footer .emp-flipper {
    display: none;
  }
  .emp-footer-name {
    font-family: 'Boska', serif;
    font-size: clamp(4rem, 10vw, 11rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -.03em;
    text-transform: uppercase;
    color: var(--emp-cream);
    opacity: .12;
    white-space: nowrap;
    align-self: center;
    justify-self: end;
  }
  @media (max-width: 700px) {
    .emp-footer {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    /* Mobile: hide logo+icons, show card */
    .emp-footer-left {
      display: none;
    }
    .emp-footer .emp-flipper {
      display: block;
      width: clamp(16rem, 85vw, 22rem);
    }
    /* Front of card - darker with bright accents (invertido) */
    .emp-footer .emp-card-front {
      background: #3d4a3c;
      box-shadow: 0 4px 32px rgba(0,0,0,.3);
    }
    .emp-footer .emp-card-front::after {
      background: var(--emp-green);
    }
    .emp-footer .emp-card-front .footer-logo-front-logo img {
      filter: brightness(10);
    }
    .emp-footer .emp-card-front .flb-email-label {
      color: var(--emp-cream);
      opacity: .75;
    }
    .emp-footer .emp-card-front .flb-handle {
      color: var(--emp-cream);
      opacity: .85;
    }
    .emp-footer .emp-card-front .footer-logo-front-social a {
      color: var(--emp-cream);
      opacity: .75;
    }
    .emp-footer .emp-card-front .footer-logo-front-social a:hover {
      color: var(--emp-green);
      opacity: 1;
    }
    .emp-footer .emp-card-front .footer-logo-front-social::before,
    .emp-footer .emp-card-front .footer-logo-front-social::after {
      color: var(--emp-cream);
      opacity: .4;
    }
    .emp-footer .emp-card-front .footer-logo-front-name {
      color: var(--emp-cream);
      opacity: .65;
    }
    /* Back of card - light cream with dark text (invertido) */
    .emp-footer .emp-card-back {
      background: var(--emp-cream);
    }
    .emp-footer .emp-card-back::after {
      background: var(--emp-green);
    }
    .emp-footer .emp-card-back .flb-logo-btn img {
      filter: none;
    }
    .emp-footer .emp-card-back .flb-email-label {
      color: var(--emp-bg);
      opacity: .75;
    }
    .emp-footer .emp-card-back .flb-handle--back {
      color: var(--emp-bg);
      opacity: .65;
    }
    .emp-footer .emp-card-back .flb-social a {
      color: var(--emp-bg);
      opacity: .65;
    }
    .emp-footer .emp-card-back .flb-social a:hover {
      opacity: 1;
    }
    .emp-footer .emp-card-back .flb-social::before,
    .emp-footer .emp-card-back .flb-social::after {
      color: var(--emp-bg);
      opacity: .35;
    }
    .emp-footer .emp-card-back .flb-origin {
      color: var(--emp-bg);
      opacity: .5;
    }
    .emp-footer-name {
      font-size: clamp(3rem, 14vw, 6rem);
      justify-self: center;
      text-align: center;
    }
  }

  /* ─── Responsive ──────────────────────────────────────────── */
  @media (max-width: 900px) {
    .emp-usos { grid-template-columns: 1fr; }
    .emp-uso { border-right: none; border-bottom: 1px solid var(--emp-border); }
    .emp-uso:last-child { border-bottom: none; }
    .emp-ventajas { grid-template-columns: 1fr; }
    .emp-pasos { grid-template-columns: 1fr 1fr; }
    .emp-form-section { grid-template-columns: 1fr; gap: 4rem; }
  }
  @media (max-width: 540px) {
    .emp-pasos { grid-template-columns: 1fr; }
    .emp-paso { border-right: none; border-bottom: 1px solid var(--emp-border); }
    .emp-form-row { grid-template-columns: 1fr; }
  }
pageScript: |
  document.getElementById('empForm').addEventListener('submit', e => {
    e.preventDefault();
    document.getElementById('empForm').style.display = 'none';
    document.getElementById('empSuccess').classList.add('visible');
  });

  // Flip card functionality
  const footerLogoInnerEmp = document.getElementById('footerLogoInnerEmp');
  const footerLogoBtnEmp = document.getElementById('footerLogoBtnEmp');
  const footerLogoBtnBackEmp = document.getElementById('footerLogoBtnBackEmp');

  if (footerLogoBtnEmp && footerLogoBtnBackEmp && footerLogoInnerEmp) {
    footerLogoBtnEmp.addEventListener('click', () => {
      footerLogoInnerEmp.classList.add('flipped');
    });
    footerLogoBtnBackEmp.addEventListener('click', () => {
      footerLogoInnerEmp.classList.remove('flipped');
    });
  }
---

<!-- ─── HERO ──────────────────────────────────────────────────── -->
<section class="emp-hero">
  <span class="emp-hero-eyebrow">{{ 'empresas.eyebrow' | t(lang) }}</span>
  <h1 class="emp-hero-title">{{ 'empresas.hero_title' | t(lang) | safe }}</h1>
  <p class="emp-hero-desc">{{ 'empresas.hero_desc' | t(lang) }}</p>
</section>

<!-- ─── USOS ──────────────────────────────────────────────────── -->
<section class="emp-usos">
  <div class="emp-uso reveal">
    <svg class="emp-uso-icon" viewBox="0 0 36 36" fill="none" stroke="currentColor" stroke-width="1.2">
      <rect x="4" y="10" width="28" height="20" rx="2"/>
      <path d="M12 10V7a6 6 0 0 1 12 0v3"/>
      <circle cx="18" cy="20" r="2"/>
    </svg>
    <h3 class="emp-uso-title">{{ 'empresas.uso1_title' | t(lang) }}</h3>
    <p class="emp-uso-desc">{{ 'empresas.uso1_desc' | t(lang) }}</p>
  </div>
  <div class="emp-uso reveal" style="transition-delay:.08s">
    <svg class="emp-uso-icon" viewBox="0 0 36 36" fill="none" stroke="currentColor" stroke-width="1.2">
      <path d="M4 28h28M8 28V16l10-8 10 8v12"/>
      <rect x="14" y="20" width="8" height="8"/>
    </svg>
    <h3 class="emp-uso-title">{{ 'empresas.uso2_title' | t(lang) }}</h3>
    <p class="emp-uso-desc">{{ 'empresas.uso2_desc' | t(lang) }}</p>
  </div>
  <div class="emp-uso reveal" style="transition-delay:.16s">
    <svg class="emp-uso-icon" viewBox="0 0 36 36" fill="none" stroke="currentColor" stroke-width="1.2">
      <rect x="4" y="8" width="28" height="20" rx="2"/>
      <path d="M4 14h28M12 14v14"/>
    </svg>
    <h3 class="emp-uso-title">{{ 'empresas.uso3_title' | t(lang) }}</h3>
    <p class="emp-uso-desc">{{ 'empresas.uso3_desc' | t(lang) }}</p>
  </div>
</section>

<!-- ─── VENTAJAS ──────────────────────────────────────────────── -->
<section class="emp-ventajas">
  <div class="emp-ventajas-left reveal">
    <span class="section-label">{{ 'empresas.ventajas_label' | t(lang) }}</span>
    <h2 class="emp-ventajas-title">{{ 'empresas.ventajas_title' | t(lang) | safe }}</h2>
  </div>
  <ul class="emp-ventajas-list reveal" style="transition-delay:.1s">
    <li>{{ 'empresas.ventaja1' | t(lang) }}</li>
    <li>{{ 'empresas.ventaja2' | t(lang) }}</li>
    <li>{{ 'empresas.ventaja3' | t(lang) }}</li>
    <li>{{ 'empresas.ventaja4' | t(lang) }}</li>
    <li>{{ 'empresas.ventaja5' | t(lang) }}</li>
    <li>{{ 'empresas.ventaja6' | t(lang) }}</li>
  </ul>
</section>

<!-- ─── PROCESO ───────────────────────────────────────────────── -->
<section class="emp-proceso">
  <div class="emp-proceso-header reveal">
    <span class="section-label">{{ 'empresas.proceso_label' | t(lang) }}</span>
    <h2>{{ 'empresas.proceso_title' | t(lang) | safe }}</h2>
  </div>
  <div class="emp-pasos">
    <div class="emp-paso reveal">
      <p class="emp-paso-num">01</p>
      <p class="emp-paso-title">{{ 'empresas.paso1_title' | t(lang) }}</p>
      <p class="emp-paso-desc">{{ 'empresas.paso1_desc' | t(lang) }}</p>
    </div>
    <div class="emp-paso reveal" style="transition-delay:.08s">
      <p class="emp-paso-num">02</p>
      <p class="emp-paso-title">{{ 'empresas.paso2_title' | t(lang) }}</p>
      <p class="emp-paso-desc">{{ 'empresas.paso2_desc' | t(lang) }}</p>
    </div>
    <div class="emp-paso reveal" style="transition-delay:.16s">
      <p class="emp-paso-num">03</p>
      <p class="emp-paso-title">{{ 'empresas.paso3_title' | t(lang) }}</p>
      <p class="emp-paso-desc">{{ 'empresas.paso3_desc' | t(lang) }}</p>
    </div>
    <div class="emp-paso reveal" style="transition-delay:.24s">
      <p class="emp-paso-num">04</p>
      <p class="emp-paso-title">{{ 'empresas.paso4_title' | t(lang) }}</p>
      <p class="emp-paso-desc">{{ 'empresas.paso4_desc' | t(lang) }}</p>
    </div>
  </div>
</section>

<!-- ─── FORMULARIO ────────────────────────────────────────────── -->
<section class="emp-form-section" id="contacto">
  <div class="emp-form-left reveal">
    <span class="section-label">{{ 'empresas.contacto_label' | t(lang) }}</span>
    <h2>{{ 'empresas.contacto_title' | t(lang) | safe }}</h2>
    <p>{{ 'empresas.contacto_desc' | t(lang) }}</p>
    <div class="emp-contact-direct">
      <p>{{ 'empresas.contacto_direct' | t(lang) }}</p>
      <a href="mailto:empresas@caverodiego.com">empresas@caverodiego.com</a>
    </div>
  </div>

  <div class="reveal emp-form-wrap" style="transition-delay:.1s">
    <form class="emp-form" id="empForm">
      <div class="emp-form-row">
        <div class="form-field">
          <label for="empNombre">{{ 'empresas.form_nombre' | t(lang) }}</label>
          <input type="text" id="empNombre" required />
        </div>
        <div class="form-field">
          <label for="empEmpresa">{{ 'empresas.form_empresa' | t(lang) }}</label>
          <input type="text" id="empEmpresa" required />
        </div>
      </div>
      <div class="form-field">
        <label for="empEmail">{{ 'empresas.form_email' | t(lang) }}</label>
        <input type="email" id="empEmail" required />
      </div>
      <div class="form-field">
        <label for="empTipo">{{ 'empresas.form_tipo' | t(lang) }}</label>
        <select id="empTipo" required>
          <option value="">{{ 'empresas.form_tipo_select' | t(lang) }}</option>
          <option value="hotel">{{ 'empresas.form_tipo_hotel' | t(lang) }}</option>
          <option value="restaurante">{{ 'empresas.form_tipo_restaurante' | t(lang) }}</option>
          <option value="retail">{{ 'empresas.form_tipo_retail' | t(lang) }}</option>
          <option value="corporativo">{{ 'empresas.form_tipo_corporativo' | t(lang) }}</option>
          <option value="otro">{{ 'empresas.form_tipo_otro' | t(lang) }}</option>
        </select>
      </div>
      <div class="form-field">
        <label for="empVolumen">{{ 'empresas.form_volumen' | t(lang) }}</label>
        <select id="empVolumen">
          <option value="">{{ 'empresas.form_tipo_select' | t(lang) }}</option>
          <option value="10-50">{{ 'empresas.form_volumen_10' | t(lang) }}</option>
          <option value="50-200">{{ 'empresas.form_volumen_50' | t(lang) }}</option>
          <option value="200-500">{{ 'empresas.form_volumen_200' | t(lang) }}</option>
          <option value="500+">{{ 'empresas.form_volumen_500' | t(lang) }}</option>
        </select>
      </div>
      <div class="form-field">
        <label for="empMensaje">{{ 'empresas.form_mensaje' | t(lang) }}</label>
        <textarea id="empMensaje" rows="4" placeholder="{{ 'empresas.form_mensaje_placeholder' | t(lang) }}"></textarea>
      </div>
      <button type="submit" class="emp-form-submit">
        {{ 'empresas.form_send' | t(lang) }}
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
      </button>
      <p class="emp-form-legal">{{ 'empresas.form_legal' | t(lang) }}</p>
    </form>

    <div class="emp-form-success" id="empSuccess">
      <h3>{{ 'empresas.form_success_title' | t(lang) }}</h3>
      <p>{{ 'empresas.form_success_desc' | t(lang) | safe }}</p>
    </div>
  </div>
</section>
