<!DOCTYPE html>
<html lang="{{ lang | default('es') }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#2a3229" />

  <!-- Primary Meta Tags -->
  <title>{{ title }}</title>
  {% if description %}<meta name="description" content="{{ description }}" />{% endif %}
  <meta name="author" content="Cavero Diego" />
  <meta name="robots" content="index, follow" />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="{% if articleDate %}article{% else %}website{% endif %}" />
  <meta property="og:url" content="{{ canonical | default(page.url) }}" />
  <meta property="og:title" content="{{ ogTitle | default(title) }}" />
  <meta property="og:description" content="{{ ogDescription | default(description) }}" />
  {% if ogImage %}<meta property="og:image" content="{{ ogImage }}" />{% endif %}
  <meta property="og:site_name" content="Cavero Diego" />
  <meta property="og:locale" content="{{ lang | default('es') }}_ES" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content="{{ canonical | default(page.url) }}" />
  <meta name="twitter:title" content="{{ ogTitle | default(title) }}" />
  <meta name="twitter:description" content="{{ ogDescription | default(description) }}" />
  {% if ogImage %}<meta name="twitter:image" content="{{ ogImage }}" />{% endif %}

  <!-- Canonical & Article Meta -->
  {% if canonical %}<link rel="canonical" href="{{ canonical }}" />{% endif %}
  {% if articleDate %}<meta property="article:published_time" content="{{ articleDate }}" />{% endif %}

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/assets/img/cv_logo.png" />

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "{% if articleDate %}Article{% else %}WebPage{% endif %}",
    "name": "{{ title }}",
    "description": "{{ description }}",
    {% if articleDate %}"datePublished": "{{ articleDate }}",{% endif %}
    "url": "{{ canonical | default(page.url) }}",
    "publisher": {
      "@type": "Organization",
      "name": "Cavero Diego",
      "logo": {
        "@type": "ImageObject",
        "url": "https://caverodiego.com/assets/img/cv_logo.png"
      }
    }
  }
  </script>

  <!-- Resource Hints -->
  <link rel="dns-prefetch" href="https://api.fontshare.com" />
  <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
  <link rel="preload" href="https://api.fontshare.com/v2/css?f[]=boska@400,500,700&f[]=satoshi@400,500&display=swap" as="style" />
  <link rel="preload" href="/assets/css/global.css" as="style" />
  <link rel="preload" href="/assets/js/global.js" as="script" />

  <!-- Stylesheets -->
  <link href="https://api.fontshare.com/v2/css?f[]=boska@400,500,700&f[]=satoshi@400,500&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
  <noscript><link href="https://api.fontshare.com/v2/css?f[]=boska@400,500,700&f[]=satoshi@400,500&display=swap" rel="stylesheet" /></noscript>
  <link rel="stylesheet" href="/assets/css/global.css" />
  {% if pageStyle %}<style>{{ pageStyle | safe }}</style>{% endif %}
</head>
<body>
  <div class="cursor" id="cursor"></div>
  <div class="cursor-ring" id="cursorRing"></div>

  {% include "partials/nav.njk" %}

  {{ content | safe }}

  {% if not noCC %}{% include "partials/cc-panel.njk" %}{% endif %}

  <script src="/assets/js/global.js" defer></script>
  {% if pageScript %}<script>{{ pageScript | safe }}</script>{% endif %}
</body>
</html>
