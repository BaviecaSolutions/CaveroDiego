  let currentLang = 'es';

  function applyLang(lang) {
    const t = translations[lang];
    document.documentElement.lang = lang;
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const key = el.dataset.i18n;
      if (t[key] !== undefined) el.textContent = t[key];
    });
    document.querySelectorAll('[data-i18n-html]').forEach(el => {
      const key = el.dataset.i18nHtml;
      if (t[key] !== undefined) el.innerHTML = t[key];
    });
    document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
      const key = el.dataset.i18nPlaceholder;
      if (t[key] !== undefined) el.placeholder = t[key];
    });
  }

  /* Lang button (nav + mobile hero) */
  function toggleLang() {
    currentLang = currentLang === 'es' ? 'en' : 'es';
    const label = currentLang.toUpperCase();
    const navLabel = document.getElementById('langLabel');
    const heroLabel = document.getElementById('heroLangLabel');
    if (navLabel) navLabel.textContent = label;
    if (heroLabel) heroLabel.textContent = label;
    applyLang(currentLang);
  }

  const langBtn = document.getElementById('langBtn');
  const heroLangBtn = document.getElementById('heroLangBtn');
  if (langBtn) langBtn.addEventListener('click', toggleLang);
  if (heroLangBtn) heroLangBtn.addEventListener('click', toggleLang);

  /* ── Loader ─────────────────────────────────────────────────────── */
  window.addEventListener('load', () => {
    setTimeout(() => {
      document.getElementById('loader').classList.add('hidden');
    }, 1000);
  });

  /* ── 3D cube drag interaction (mobile only) ─────────────────────── */
  const cubeContainer = document.querySelector('.cube-container');
  if (cubeContainer && window.innerWidth <= 560) {
    let rotX = 20, rotY = 20;
    let isDragging = false;
    let startX, startY;

    function updateCube() {
      cubeContainer.style.transform = `rotateX(${rotX}deg) rotateY(${rotY}deg)`;
    }

    cubeContainer.addEventListener('mousedown', (e) => {
      isDragging = true;
      startX = e.clientX;
      startY = e.clientY;
    });

    cubeContainer.addEventListener('touchstart', (e) => {
      isDragging = true;
      startX = e.touches[0].clientX;
      startY = e.touches[0].clientY;
    });

    const onMove = (clientX, clientY) => {
      if (!isDragging) return;
      const deltaX = clientX - startX;
      const deltaY = clientY - startY;
      rotY += deltaX * 0.5;
      rotX -= deltaY * 0.5;
      startX = clientX;
      startY = clientY;
      updateCube();
    };

    document.addEventListener('mousemove', (e) => onMove(e.clientX, e.clientY));
    document.addEventListener('touchmove', (e) => {
      if (isDragging) {
        e.preventDefault();
        onMove(e.touches[0].clientX, e.touches[0].clientY);
      }
    }, { passive: false });

    const onEnd = () => { isDragging = false; };
    document.addEventListener('mouseup', onEnd);
    document.addEventListener('touchend', onEnd);

    updateCube();
  }
