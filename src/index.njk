---
layout: layouts/standard.njk
title: "CAVERO DIEGO"
section: home
pageStyle: |
  /* Nav background comes from global.css */

  /* ─── Page loader ───────────────────────────────────────────── */
  #loader {
    position: fixed; inset: 0;
    background: var(--ink);
    display: flex; align-items: center; justify-content: center;
    z-index: 9000;
    transition: opacity .8s ease, visibility .8s ease;
  }
  #loader.hidden { opacity: 0; visibility: hidden; }
  .loader-logo {
    width: 64px; height: 64px;
    animation: spinLogo 1.2s linear infinite;
    filter: invert(1);
  }
  @keyframes spinLogo {
    to { transform: rotate(360deg); }
  }

  /* ─── Hero ──────────────────────────────────────────────────── */
  #hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0 8vw 8vh;
    overflow: hidden;
    position: relative;
  }
  .hero-bg {
    position: absolute;
    inset: 6rem 2vw 2vw;
    border-radius: 4px;
    overflow: visible;
    z-index: 0;
    background-color: var(--ink);
  }
  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    border-radius: 4px;
  }
  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 4px;
    background: rgba(74, 84, 56, 0.45);
  }
  #hero > *:not(.hero-bg) {
    position: relative;
    z-index: 1;
  }

  .hero-title {
    position: absolute;
    bottom: -.15em;
    right: -.01em;
    z-index: 2;
    font-family: 'Boska', serif;
    font-size: clamp(5rem, 14.5vw, 17rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -.03em;
    color: var(--cream);
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
  }
  .hero-title .line {
    display: block;
    transform: translateY(110%);
    animation: slideUp .9s cubic-bezier(.16,1,.3,1) forwards;
  }
  @keyframes slideUp { to { transform: translateY(0); } }

  .hero-accent {
    display: inline-block;
    width: 8px; height: 8px;
    background: var(--blue);
    border-radius: 50%;
    vertical-align: super;
    margin-left: .15em;
  }

  .hero-bottom {
    margin-top: 3.6rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 4vw;
    transform: translateY(20px);
    opacity: 0;
    animation: fadeUp .8s .5s ease forwards;
  }
  .hero-sub {
    max-width: 32ch;
    color: var(--stone);
    font-size: .88rem;
    line-height: 1.7;
  }
  .hero-cta {
    display: flex; align-items: center; gap: 2rem;
    flex-shrink: 0;
  }
  @keyframes fadeUp { to { transform: translateY(0); opacity: 1; } }

  .btn-primary {
    display: inline-flex; align-items: center; gap: .8rem;
    background: var(--ink);
    color: var(--cream);
    font-family: 'Satoshi', sans-serif;
    font-size: .7rem;
    letter-spacing: .22em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 1.05rem 2.4rem;
    border: 1px solid var(--ink);
    transition: background .3s, color .3s;
  }
  .btn-primary:hover { background: var(--blue); border-color: var(--blue); }

  .btn-ghost {
    font-size: .7rem;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--stone);
    text-decoration: none;
    display: flex; align-items: center; gap: .5rem;
    transition: color .3s;
  }
  .btn-ghost svg { transition: transform .3s; }
  .btn-ghost:hover { color: var(--ink); }
  .btn-ghost:hover svg { transform: translateX(4px); }

  .hero-scroll-hint {
    position: absolute; bottom: 2.8rem; right: 8vw;
    display: flex; flex-direction: column; align-items: center; gap: .6rem;
    z-index: 10;
  }
  .hero-scroll-hint span {
    font-size: .6rem; letter-spacing: .25em;
    text-transform: uppercase; color: var(--stone);
    writing-mode: vertical-rl;
  }
  .hero-scroll-line {
    width: 1px; height: 48px;
    background: var(--stone);
    transform-origin: top;
    animation: growLine 1.2s 1s ease forwards;
    transform: scaleY(0);
  }
  @keyframes growLine { to { transform: scaleY(1); } }

  /* ─── Marquee strip ─────────────────────────────────────────── */
  .marquee-strip {
    border-top: 1px solid var(--ink-10);
    border-bottom: 1px solid var(--ink-10);
    overflow: hidden;
    padding: 1.1rem 0;
    background: var(--cream);
  }
  .marquee-inner {
    display: flex; white-space: nowrap;
    animation: marquee 28s linear infinite;
  }
  .marquee-inner span {
    font-family: 'Boska', serif;
    font-size: clamp(.9rem, 2vw, 1.4rem);
    letter-spacing: .14em;
    color: var(--ink);
    padding: 0 3rem;
  }
  .marquee-inner .dot { color: var(--blue); padding: 0; }
  @keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  /* ─── Territorio ─────────────────────────────────────────────── */
  #territorio {
    padding: 14vh 8vw 0;
  }
  .territorio-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 2vw;
    align-items: end;
  }
  .territorio-img {
    aspect-ratio: 4/6;
    border-radius: 2px;
    position: relative;
    overflow: hidden;
  }
  .territorio-img::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url('/assets/img/hero_mobile.png') center bottom 10%/cover no-repeat;
  }
  .territorio-img-overlay {
    position: absolute;
    inset: 0;
    background: rgba(74,84,56,0.52);
  }
  .territorio-aside {
    padding-bottom: 4vh;
    display: flex; flex-direction: column; gap: 2.4rem;
  }
  .territorio-aside .section-label { margin-bottom: .6rem; }
  .territorio-aside h2 {
    font-family: 'Boska', serif;
    font-size: clamp(2rem, 4vw, 3.8rem);
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -.01em;
  }
  .territorio-aside p {
    font-size: .86rem;
    color: var(--stone);
    line-height: 1.9;
    max-width: 36ch;
  }

  /* ─── Manifiesto ─────────────────────────────────────────────── */
  #manifiesto {
    padding: 18vh 8vw;
    border-top: 1px solid var(--ink-10);
    max-width: 1100px;
  }
  .manifiesto-label {
    display: block;
    margin-bottom: 3rem;
  }
  .manifiesto-body {
    font-family: 'Boska', serif;
    font-size: clamp(1.8rem, 3.8vw, 4rem);
    font-weight: 400;
    line-height: 1.18;
    letter-spacing: -.01em;
    color: var(--ink);
  }
  .manifiesto-body em {
    font-style: italic;
    color: var(--stone);
  }

  /* ─── Divider quote ──────────────────────────────────────────── */
  .divider-quote {
    padding: 12vh 8vw;
    display: flex;
    align-items: center;
    gap: 4vw;
  }
  .divider-quote::before,
  .divider-quote::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--ink-10);
  }
  .divider-quote img {
    height: clamp(4rem, 10vw, 9rem);
    opacity: .12;
  }

  /* ─── Materiales ─────────────────────────────────────────────── */
  #materiales {
    padding: 0 8vw 14vh;
  }
  .materiales-header {
    padding: 10vh 0 6vh;
    display: flex; justify-content: space-between; align-items: flex-end;
  }
  .materiales-header h2 {
    font-family: 'Boska', serif;
    font-size: clamp(2rem, 4.5vw, 4.2rem);
    font-weight: 400;
    line-height: 1;
  }
  .materiales-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2vw;
  }
  .mat-cell {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    text-decoration: none;
    color: var(--ink);
  }
  .mat-cell:hover .mat-cell-img { opacity: .85; }
  .mat-cell .mat-cell-img { transition: opacity .3s; }
  .mat-cell-img {
    width: 100%;
    aspect-ratio: 3/4;
    background: #2a3229;
    border-radius: 2px;
    position: relative;
  }
  .mat-cell-img::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(74,84,56,0.45);
    border-radius: 2px;
  }
  .mat-cell-label { display: flex; flex-direction: column; gap: .4rem; }
  .mat-cell-label span {
    font-size: .58rem;
    letter-spacing: .28em;
    text-transform: uppercase;
    color: var(--stone);
  }
  .mat-cell-label h3 {
    font-family: 'Boska', serif;
    font-size: clamp(1.4rem, 2.5vw, 2.2rem);
    font-weight: 400;
    color: var(--ink);
    line-height: 1.1;
  }
  .mat-cell-label p {
    font-size: .8rem;
    color: var(--stone);
    line-height: 1.7;
    max-width: 38ch;
    margin-top: .4rem;
  }
  .mat-pronto {
    display: inline-block;
    margin-top: .8rem;
    font-size: .58rem;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--blue);
  }

  /* ─── Origen ─────────────────────────────────────────────────── */
  #origen {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 55vh;
    border-top: 1px solid var(--ink-10);
  }
  .origen-img {
    background: #3d4a3c;
    max-height: 65vh;
    overflow: hidden;
  }
  .origen-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .origen-content {
    padding: 10vh 7vw;
    display: flex; flex-direction: column; justify-content: center; gap: 2.4rem;
    background: var(--ink);
    color: var(--cream);
  }
  .origen-content .section-label { color: rgba(232,229,220,.35); }
  .origen-title {
    font-family: 'Boska', serif;
    font-size: clamp(2rem, 3.5vw, 3.4rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -.01em;
  }
  .origen-body {
    font-size: .86rem;
    color: rgba(232,229,220,.55);
    line-height: 1.9;
    max-width: 38ch;
  }

  /* ─── Lista de espera ────────────────────────────────────────── */
  #espera {
    background: var(--ink);
    color: var(--cream);
    padding: 16vh 8vw;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8vw;
    align-items: center;
    border-top: 1px solid rgba(232,229,220,.06);
  }
  .espera-title {
    font-family: 'Boska', serif;
    font-size: clamp(2.2rem, 4.5vw, 4.8rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -.01em;
  }
  .espera-title em { font-style: italic; color: var(--stone); }
  .espera-sub {
    margin-top: 1.6rem;
    font-size: .82rem;
    color: rgba(232,229,220,.4);
    line-height: 1.8;
    max-width: 36ch;
  }
  .espera-form {
    display: flex; flex-direction: column; gap: 1.2rem;
  }
  .form-input {
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(232,229,220,.2);
    padding: 1.1rem 0;
    font-family: 'Satoshi', sans-serif;
    font-size: .8rem;
    letter-spacing: .06em;
    color: var(--cream);
    outline: none;
    transition: border-color .3s;
    width: 100%;
  }
  .form-input::placeholder { color: rgba(232,229,220,.28); }
  .form-input:focus { border-color: var(--blue); }
  .form-submit {
    align-self: flex-start;
    display: inline-flex; align-items: center; gap: .8rem;
    background: var(--blue);
    color: #fff;
    font-family: 'Satoshi', sans-serif;
    font-size: .7rem;
    letter-spacing: .22em;
    text-transform: uppercase;
    border: none;
    padding: 1.1rem 2.6rem;
    cursor: none;
    transition: opacity .3s;
    margin-top: .4rem;
  }
  .form-submit:hover { opacity: .85; }

  /* ─── Cuaderno preview ───────────────────────────────────────── */
  #cuaderno-preview {
    padding: 14vh 8vw;
    border-top: 1px solid var(--ink-10);
  }
  .cuaderno-preview-header {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 6vh;
  }
  .cuaderno-preview-header h2 {
    font-family: 'Boska', serif;
    font-size: clamp(2rem, 4.5vw, 4.2rem);
    font-weight: 400; line-height: 1;
  }
  .cuaderno-preview-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 1.5px;
    border: 1px solid var(--ink-10);
  }
  .cp-card {
    text-decoration: none; color: var(--ink);
    display: flex; flex-direction: column;
    transition: background .3s;
  }
  .cp-card:hover { background: var(--ink-4); }
  .cp-card-img {
    aspect-ratio: 3/2;
    background: #4a5438;
  }
  .cp-card.tall .cp-card-img { aspect-ratio: auto; flex: 1; min-height: 200px; }
  .cp-card { border-right: 1px solid var(--ink-10); }
  .cp-card-body { padding: 1.8rem 2rem 2rem; display: flex; flex-direction: column; gap: .6rem; }
  .cp-cat {
    font-size: .56rem; letter-spacing: .28em;
    text-transform: uppercase; color: var(--blue);
  }
  .cp-titulo {
    font-family: 'Boska', serif;
    font-size: clamp(1rem, 1.8vw, 1.5rem);
    font-weight: 400; line-height: 1.15;
  }
  .cp-leer {
    margin-top: .6rem;
    font-size: .58rem; letter-spacing: .2em;
    text-transform: uppercase; color: var(--stone);
    display: flex; align-items: center; gap: .4rem;
    transition: color .3s;
  }
  .cp-card:hover .cp-leer { color: var(--ink); }
  .cp-leer svg { transition: transform .3s; }
  .cp-card:hover .cp-leer svg { transform: translateX(4px); }
  .cuaderno-preview-cta {
    margin-top: 4vh;
    display: flex; justify-content: flex-end;
  }

  /* ─── Desktop-only: hide mobile elements ────────────────────── */
  .hero-mobile-wordmark,
  .hero-mobile-nav,
  .hero-mobile-image,
  .hero-mobile-intro,
  .hero-mobile-cube {
    display: none;
  }

  /* ─── Responsive ─────────────────────────────────────────────── */
  @media (min-width: 561px) {
    /* Desktop: mostrar texto completo, ocultar versión móvil */
    .text-mobile-only {
      display: none;
    }
    .text-desktop-only {
      display: inline;
    }
  }

  @media (max-width: 900px) {
    #hero { padding: 0 6vw 7vh; }
    .hero-bg { inset: 5rem 2vw 12vh; }
    .hero-title { font-size: clamp(4rem, 12vw, 9rem); white-space: normal; }
    .territorio-grid { grid-template-columns: 1fr; }
    #territorio { padding: 8vh 6vw 0; }
    .materiales-grid { grid-template-columns: 1fr 1fr; }
    .mat-cell.tall { grid-row: span 1; }
    #origen { grid-template-columns: 1fr; }
    .origen-img { min-height: 32vh; }
    #espera { grid-template-columns: 1fr; }
    .cuaderno-preview-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    /* Usar estructura desktop adaptada */
    #hero {
      min-height: 105vh;
      padding: 0;
    }

    /* Usar hero-bg de desktop pero adaptado */
    .hero-bg {
      display: block;
      position: absolute;
      inset: 0;
      border-radius: 0;
      overflow: visible;
      z-index: 0;
      background-color: var(--ink);
    }
    .hero-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      display: block;
      border-radius: 0;
    }
    .hero-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 0;
      background: rgba(74, 84, 56, 0.45);
    }

    /* Usar hero-title de desktop pero adaptado */
    .hero-title {
      display: block;
      position: absolute;
      bottom: 50%;
      right: 50%;
      transform: translate(50%, 50%);
      z-index: 2;
      font-size: clamp(5.5rem, 18vw, 8rem);
      text-align: center;
    }
    .hero-title .line {
      display: block;
      transform: translateY(0);
      animation: none;
    }

    /* Ocultar bottom en mobile */
    .hero-bottom {
      display: none;
    }

    /* Ocultar elementos mobile específicos */
    .hero-mobile-nav,
    .hero-mobile-image,
    .hero-mobile-wordmark,
    .hero-mobile-intro,
    .hero-mobile-cube {
      display: none;
    }

    .materiales-grid {
      grid-template-columns: 1fr;
      gap: 3vh;
    }
    .mat-cell-label h3 {
      font-size: clamp(1rem, 3.5vw, 1.4rem);
    }
    .mat-cell-label p {
      font-size: .72rem;
      line-height: 1.5;
    }
    .mat-cell-label span {
      font-size: .52rem;
    }
    .mat-pronto {
      font-size: .52rem;
      margin-top: .5rem;
    }
    #manifiesto { padding: 12vh 6vw; }
    .divider-quote { padding: 6vh 6vw; }
    .cuaderno-preview-grid { grid-template-columns: 1fr; }

    /* ─── Colores de fondo contrastados para Territorio y Manifiesto ──── */
    #territorio {
      padding: 10vh 6vw;
      background: linear-gradient(180deg, var(--cream) 0%, rgba(42,50,41,.08) 100%);
    }

    #manifiesto {
      padding: 10vh 6vw 12vh;
      background: linear-gradient(180deg, rgba(42,50,41,.12) 0%, rgba(42,50,41,.05) 50%, var(--cream) 100%);
      border-top: none;
      border-bottom: none;
    }

    /* Reducir texto en móvil - versión corta */
    .text-desktop-only {
      display: none;
    }
    .text-mobile-only {
      display: block;
    }

    .manifiesto-body {
      font-size: clamp(1.4rem, 5vw, 2.2rem);
    }
    .origen-img {
      min-height: 24vh;
      max-height: 30vh;
    }

    /* Territorio mobile: imagen pequeña a la izquierda */
    .territorio-grid {
      display: flex;
      flex-direction: row;
      gap: 4vw;
      align-items: flex-start;
    }
    .territorio-img {
      width: 30%;
      aspect-ratio: 4/9;
      flex-shrink: 0;
      order: 1;
    }
    .territorio-img::before {
      background-size: cover !important;
      background-position: center !important;
    }
    .territorio-aside {
      order: 2;
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      padding-bottom: 0;
    }
    .territorio-aside h2 {
      font-size: clamp(1.6rem, 5.5vw, 2.2rem);
    }
    .territorio-aside p {
      font-size: .8rem;
      line-height: 1.7;
    }
  }
