# ============================================
# Docker ignore file for production builds
# Excludes unnecessary files from Docker context
# ============================================

# Git
.git
.gitignore
.gitattributes

# Build output (will be generated in container)
_site/
dist/
build/

# Dependencies (will be installed in container)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# Environment variables
.env
.env.*
!.env.example

# Logs
*.log
logs/

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Editor directories and files
.vscode/
.idea/
*.swp
*.swo
*.swn
*.bak
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# Testing
coverage/
.nyc_output/
*.test.js
*.spec.js
__tests__/
test/
tests/

# Cache directories
.cache/
.parcel-cache/
.next/
.nuxt/
.sass-cache/
*.cache

# Temporary files
tmp/
temp/
*.tmp

# Documentation
README.md
CHANGELOG.md
LICENSE
*.md
docs/

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
.circleci/
azure-pipelines.yml
bitbucket-pipelines.yml

# Docker files (no need to copy into image)
Dockerfile*
docker-compose*.yml
.dockerignore

# Netlify
netlify.toml
.netlify/

# Claude
.claude/

# Project specific
ADN de marca.pdf
